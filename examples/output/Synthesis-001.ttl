    VOC4CAT:0007246 <https://pubchem.ncbi.nlm.nih.gov/compound/962> ;
    VOC4CAT:0008104 "gamma-Al2O3, Sasol Puralox, 200 m2/g" ;
    VOC4CAT:0008105 "stored in desiccator under argon atmosphere at room temperature" .

<https://pubchem.ncbi.nlm.nih.gov/compound/962> a CHEBI:23367 ;
    dcterms:title "deionized water" .

coremeta4cat:PREC_001_H2PtCl6 a VOC4CAT:0007794 ;
