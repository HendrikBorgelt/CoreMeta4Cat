        coremeta4cat:CAT_32x1-99x6_SiO2_5P,
        coremeta4cat:CHAR_32x1-99x6_PXRD_method ;
    prov:wasAssociatedWith coremeta4cat:DEV_32x1-99x6_PXRD .

coremeta4cat:CHAR_32x1-99x6_PXRD_method a OBI:0000272 ;
    dcterms:description "Two-theta scan, ~2-92 degrees, step size 0.015 degrees. One file (PXRD_1PSiO2.xy) is a Pd-free P/SiO2 support reference; one file (PXRD_Pd5Al2O3.xy) is missing the 'P' in its name but is interpreted as the nominal 5 wt% P/Al2O3 sample based on the file series context (matches ICP sample FR507)." ;
    dcterms:title "Powder XRD measurement method" .

