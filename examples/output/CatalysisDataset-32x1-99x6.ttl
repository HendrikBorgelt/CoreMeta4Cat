coremeta4cat:REAC_32x1-99x6_Citral_Al2O3 a coremeta4cat:CatalyticReaction,
        VOC4CAT:0000260 ;
    RO:0004009 coremeta4cat:REAC_32x1-99x6_Citral_Al2O3_H2,
